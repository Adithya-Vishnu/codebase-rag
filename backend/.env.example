# Copy to .env and fill in real values.

# Supabase (or any Postgres with pgvector): Connect dialog -> Connection string (URI).
# NOTE: the direct db.*.supabase.co host is IPv6-only. On IPv4 networks use the
# Session pooler string instead (user postgres.PROJECT_REF, host aws-N-REGION.pooler.supabase.com).
# URL-encode special characters in the password (e.g. ! -> %21).
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-YOUR_REGION.pooler.supabase.com:5432/postgres

# https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Optional override; must be a model with free-tier quota for your key
GEMINI_MODEL=gemini-2.5-flash

# Comma-separated origins allowed by CORS (add your Vercel URL after deploy)
CORS_ORIGINS=http://localhost:5173
